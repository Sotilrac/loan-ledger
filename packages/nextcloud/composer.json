{
  "name": "loan-ledger/nextcloud",
  "description": "Nextcloud app for Loan Ledger",
  "type": "project",
  "license": "MPL-2.0",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "bamarni/composer-bin-plugin": "^1.8",
    "nextcloud/ocp": "dev-stable33",
    "roave/security-advisories": "dev-latest"
  },
  "config": {
    "optimize-autoloader": true,
    "classmap-authoritative": true,
    "platform": {
      "php": "8.2"
    },
    "sort-packages": true,
    "allow-plugins": {
      "bamarni/composer-bin-plugin": true
    }
  },
  "extra": {
    "bamarni-bin": {
      "bin-links": false,
      "forward-command": false
    }
  },
  "autoload": {
    "psr-4": {
      "OCA\\LoanLedger\\": "lib/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OCA\\LoanLedger\\Tests\\": "tests/",
      "OCP\\": "vendor/nextcloud/ocp/OCP/",
      "NCU\\": "vendor/nextcloud/ocp/NCU/"
    }
  },
  "scripts": {
    "post-install-cmd": [
      "@composer bin all install --ansi"
    ],
    "post-update-cmd": [
      "@composer bin all update --ansi"
    ],
    "test": "vendor-bin/phpunit/vendor/bin/phpunit --configuration tests/phpunit.xml",
    "psalm": "vendor-bin/psalm/vendor/bin/psalm",
    "cs:check": "vendor-bin/cs-fixer/vendor/bin/php-cs-fixer fix --dry-run --diff",
    "cs:fix": "vendor-bin/cs-fixer/vendor/bin/php-cs-fixer fix"
  }
}
