{
  "name": "@loan-ledger/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Shared Vue components, charts, and stores for Loan Ledger targets.",
  "license": "MPL-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*",
    "./charts/*": "./src/charts/*",
    "./stores/*": "./src/stores/*",
    "./source/*": "./src/source/*",
    "./util/*": "./src/util/*",
    "./format": "./src/format.ts",
    "./style/tokens.css": "./src/style/tokens.css",
    "./style/typography.css": "./src/style/typography.css",
    "./style/base.css": "./src/style/base.css"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@loan-ledger/core": "workspace:*",
    "@phosphor-icons/vue": "^2.2.1",
    "pinia": "^3.0.4",
    "vue": "^3.5.33"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^25.0.1",
    "vite": "^8.0.9",
    "vitest": "^4.1.5",
    "vue-tsc": "^3.2.7"
  }
}
