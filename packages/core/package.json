{
  "name": "@loan-ledger/core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript core: engines, types, schemas, parsing.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/*.json": "./src/schemas/*.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/papaparse": "^5.5.2",
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "ajv": "^8.18.0",
    "ajv-formats": "^3.0.1",
    "js-yaml": "^4.1.1",
    "papaparse": "^5.5.3"
  }
}
