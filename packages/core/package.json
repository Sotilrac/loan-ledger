{
  "name": "@loan-ledger/core",
  "version": "0.0.0",
  "private": true,
  "description": "Shared TypeScript core: engines, types, schemas, parsing.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./schemas/*.json": "./src/schemas/*.json"
  },
  "files": [
    "dist",
    "src/schemas"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "vitest": "^4.1.5"
  }
}
